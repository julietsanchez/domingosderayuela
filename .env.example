# Copiar a .env.local para `vercel dev` o definir en Vercel → Settings → Environment Variables.
# No commitear archivos .env con valores reales.

# Resend — API Key (secreto)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Remitente: debe ser un dominio o correo verificado en Resend.
# Formato sugerido: "Domingos de Rayuela <no-reply@tudominio.com>"
MAIL_FROM=

# Destinatario principal (To) — una sola casilla
MAIL_TO=

# Opcional — varias casillas separadas por comas (se envían como BCC)
# MAIL_BCC=equipo1@dominio.com, equipo2@dominio.com

# ----- Convocatoria /sumate (opcional; si no definís nada, usa las mismas claves que arriba) -----
# Casilla distinta para postulaciones de voluntariado:
# MAIL_TO_SUMATE=convocatoria@tudominio.com
# Remitente distinto (verificado en Resend):
# MAIL_FROM_SUMATE=Domingos de Rayuela Convocatoria <convocatoria@tudominio.com>
# BCC solo para sumate (no usa MAIL_BCC de “Quiero ayudar”):
# MAIL_BCC_SUMATE=
# Otra API key de Resend solo para sumate:
# RESEND_API_KEY_SUMATE=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

